DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=

# Banco de produção (Render + Neon) — sem isso, cai pro SQLite local automaticamente.
DATABASE_URL=

# Storage de mídia em produção (Cloudinary) — crie uma conta gratuita em
# https://cloudinary.com e copie essas 3 chaves do dashboard. Sem isso, as
# imagens continuam indo pro disco local (bom pra dev).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Spotify (painel "ouvindo agora") — crie um app em https://developer.spotify.com/dashboard
# e cadastre SPOTIFY_REDIRECT_URI como Redirect URI desse app.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/spotify/callback/

# GitHub (painel de estatísticas) — gere um token em https://github.com/settings/tokens
# (sem nenhum escopo marcado já basta pra dados públicos) e rode depois:
#   python manage.py refresh_github_stats
GITHUB_USERNAME=
GITHUB_TOKEN=
